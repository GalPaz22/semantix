                        <input
                          type="text"
                          value={siteConfig.nativeCard.map.linkSelector}
                          onChange={(e) => {
                            console.log('Link selector value:', e.target.value);
                            setSiteConfig({
                              ...siteConfig,
                              nativeCard: {
                                ...siteConfig.nativeCard,
                                map: {
                                  ...siteConfig.nativeCard.map,
                                  linkSelector: e.target.value
                                }
                              }
