                          })}
                          placeholder=".price"
                          className="w-full p-2 border border-gray-200 rounded text-sm"
                        />
                      </div>
                      
                      <div>
                        <label className="block text-xs text-gray-600 mb-1">Image Selector</label>
                        <input
                          type="text"
                          value={siteConfig.nativeCard.map.imageSelector}
                          onChange={(e) => setSiteConfig({
